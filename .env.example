# Environment Variables
# Copy this file to .env and fill in your values

# === IAMHC LLM API (for research agent) ===
IAMHC_API_KEY=your_iamhc_api_key_here
IAMHC_BASE_URL=https://api.iamhc.cn

# === Wallet Private Keys (NEVER commit real keys!) ===
PRIVATE_KEYS=

# === RPC URLs ===
RPC_ETH_MAINNET=https://eth.llamarpc.com
RPC_BSC_MAINNET=https://bsc-dataseed.binance.org
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_BASE=https://mainnet.base.org
RPC_POLYGON=https://polygon-rpc.com

# === Optional: AI Model for Research ===
AI_MODEL=Qwen3.5-397B-A17B
AI_REASONING_MODEL=deepseek-v3.2

# === Gas Settings ===
MAX_GAS_GWEI=50
GAS_MULTIPLIER=1.1
